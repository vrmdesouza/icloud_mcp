# iCloud credentials (shared by Mail and Calendar)
# The same App-Specific Password works for IMAP/SMTP and CalDAV.
ICLOUD_EMAIL=you@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional configuration
IMAP_POOL_SIZE=3
IMAP_TIMEOUT=30
CALDAV_TIMEOUT=30
EVENTKIT_TIMEOUT=30

# Reminders use the native macOS Reminders app via EventKit (no credential).
# macOS only: grant Reminders access to the process running the server
# (Claude Desktop, or the terminal when running via `uv run`) in
# Ajustes do Sistema → Privacidade e Segurança → Lembretes. The first call
# triggers the permission prompt.
